   year = {2022},
}
@article{Mahmoudabadbozchelou2022,
   abstract = {<p>A series of physics-informed neural networks for prediction of time- and rate-dependent material functions in non-Newtonian fluids in response to different deformation fields are presented and rigorously interrogated against conventional CFD solutions.</p>},
   author = {Mohammadamin Mahmoudabadbozchelou and George Em. Karniadakis and Safa Jamali},
   doi = {10.1039/D1SM01298C},
   issn = {1744-683X},
   issue = {1},
   journal = {Soft Matter},
   pages = {172-185},
   title = {nn-PINNs: Non-Newtonian physics-informed neural networks for complex fluid modeling},
   volume = {18},
   year = {2022},
}
